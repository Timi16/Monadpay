{
  "name": "@monadpay/backend",
  "version": "0.1.0",
  "main": "dist/index.js",
  "scripts": {
    "predev": "yarn workspace @monadpay/sdk build",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "prebuild": "yarn workspace @monadpay/sdk build",
    "build": "tsc -p tsconfig.json",
    "pretest": "yarn workspace @monadpay/sdk build",
    "test": "vitest run",
    "prisma": "prisma"
  },
  "prisma": {
    "schema": "../../prisma/schema.prisma"
  },
  "dependencies": {
    "@monadpay/sdk": "*",
    "@prisma/client": "^6.6.0",
    "ethers": "^6.13.0",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/supertest": "^6.0.3",
    "prisma": "^6.6.0",
    "supertest": "^7.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
